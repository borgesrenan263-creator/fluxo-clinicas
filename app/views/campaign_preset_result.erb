<div class="section-title">
  <div>
    <h2>Preset de campanha criado</h2>
    <p class="muted"><%= h @result[:label] %></p>
  </div>

  <a class="button" href="/campaigns">Voltar para campanhas</a>
</div>

<div class="cards">
  <div class="card">
    <h2>Templates criados</h2>
    <strong><%= @result[:created] %></strong>
  </div>

  <div class="card">
    <h2>Ignorados por duplicidade</h2>
    <strong><%= @result[:skipped] %></strong>
  </div>
</div>
