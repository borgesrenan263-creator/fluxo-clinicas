<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Clínicas Pro</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/css/premium.css">
</head>
<body>
  <% current_path = request.path_info %>

  <input type="checkbox" id="menu-toggle" class="menu-toggle">

  <div class="enterprise-app">
    <aside class="push-sidebar">
      <div class="sidebar-inner">
        <div class="brand-pro">
          <div class="logo-pro">
            <div class="logo-orbit"></div>
            <div class="logo-cross">
              <span></span>
              <span></span>
            </div>
            <div class="logo-smile"></div>
          </div>

          <div>
            <h1>Clínicas Pro</h1>
            <p>Enterprise Growth System</p>
          </div>
        </div>

        <nav class="menu-list">
          <div class="menu-group">
            <div class="menu-group-title">Crescimento</div>

            <a class="menu-item <%= 'active' if current_path == '/' %>" href="/">
              <span class="menu-icon">D</span>
              <span>Dashboard</span>
            </a>

            <a class="menu-item <%= 'active' if current_path == '/prospects/work' %>" href="/prospects/work">
              <span class="menu-icon">M</span>
              <span>Mesa de Trabalho</span>
            </a>

            <a class="menu-item <%= 'active' if current_path == '/prospects' %>" href="/prospects?phone=with">
              <span class="menu-icon">P</span>
              <span>Prospects com contato</span>
            </a>

            <a class="menu-item <%= 'active' if current_path == '/companies' %>" href="/companies">
              <span class="menu-icon">C</span>
              <span>Clientes</span>
            </a>

            <a class="menu-item <%= 'active' if current_path == '/finance' || current_path == '/finance/new' %>" href="/finance">
              <span class="menu-icon">R$</span>
              <span>Financeiro</span>
            </a>
          </div>

          <div class="menu-group">
            <div class="menu-group-title">Operação da clínica</div>

            <a class="menu-item <%= 'active' if current_path == '/contacts' %>" href="/contacts">
              <span class="menu-icon">L</span>
              <span>Contatos</span>
            </a>

            <a class="menu-item <%= 'active' if current_path == '/contacts/new' %>" href="/contacts/new">
              <span class="menu-icon">+</span>
              <span>Novo contato</span>
            </a>

            <a class="menu-item <%= 'active' if current_path == '/campaigns' %>" href="/campaigns">
              <span class="menu-icon">C</span>
              <span>Campanhas</span>
            </a>

            <a class="menu-item <%= 'active' if current_path == '/messages' %>" href="/messages">
              <span class="menu-icon">W</span>
              <span>Mensagens</span>
            </a>

            <a class="menu-item <%= 'active' if current_path == '/responses' %>" href="/responses">
              <span class="menu-icon">R</span>
              <span>Respostas</span>
            </a>
          </div>

          <div class="menu-group">
            <div class="menu-group-title">Sistema</div>

            <a class="menu-item <%= 'active' if current_path == '/imports' %>" href="/imports">
              <span class="menu-icon">I</span>
              <span>Importar contatos</span>
            </a>

            <a class="menu-item <%= 'active' if current_path == '/prospects/import' %>" href="/prospects/import">
              <span class="menu-icon">B2B</span>
              <span>Importar prospects</span>
            </a>

            <a class="menu-item <%= 'active' if current_path == '/reports' || current_path == '/reports/pdf' %>" href="/reports">
              <span class="menu-icon">PDF</span>
              <span>Relatórios</span>
            </a>

            <a class="menu-item <%= 'active' if current_path == '/health' %>" href="/health">
              <span class="menu-icon">OK</span>
              <span>Health</span>
            </a>

            <a class="menu-item <%= 'active' if current_path == '/metrics' %>" href="/metrics">
              <span class="menu-icon">M</span>
              <span>Metrics</span>
            </a>
          </div>
        </nav>
      </div>
    </aside>

    <div class="push-content">
      <header class="enterprise-header">
        <div class="header-left">
          <label for="menu-toggle" class="menu-button">
            <span></span>
            <span></span>
            <span></span>
          </label>
        </div>

        <div class="header-center">
          <div class="mini-logo-pro">
            <div class="mini-logo-core"></div>
          </div>

          <div>
            <h1>Clínicas Pro</h1>
            <p>Central Enterprise de crescimento para clínicas</p>
          </div>
        </div>

        <div class="header-right">
          <span class="enterprise-badge">White Neon Blue</span>
        </div>
      </header>

      <main class="content">
        <%= yield %>
      </main>
    </div>
  </div>
</body>
</html>
