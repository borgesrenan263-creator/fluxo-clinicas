<div class="section-title">
  <div>
    <h2>Prospects B2B</h2>
    <p class="muted">Clínicas prospectadas para vender o serviço de reativação.</p>
  </div>

  <div>
    <a class="button" href="/prospects/import">Importar 50 clínicas</a>

    <form method="post" action="/prospects/archive_ignored" style="display:inline;">
      <button type="submit">Arquivar ignorados 48h</button>
    </form>
  </div>
</div>

<div class="cards">
  <div class="card">
    <h2>Total</h2>
    <strong><%= @total_prospects %></strong>
  </div>

  <div class="card">
    <h2>Novos</h2>
    <strong><%= @new_prospects %></strong>
  </div>

  <div class="card">
    <h2>Com telefone</h2>
    <strong><%= @with_phone %></strong>
  </div>

  <div class="card">
    <h2>Sem telefone</h2>
    <strong><%= @without_phone %></strong>
  </div>

  <div class="card">
    <h2>Contatados</h2>
    <strong><%= @contacted_prospects %></strong>
  </div>

  <div class="card">
    <h2>Clientes</h2>
    <strong><%= @client_prospects %></strong>
  </div>

  <div class="card">
    <h2>Ignorados</h2>
    <strong><%= @ignored_prospects %></strong>
  </div>
</div>

<div class="card">
  <strong>Status:</strong>
  <a href="/prospects">Todos</a> |
  <a href="/prospects?status=novo">Novos</a> |
  <a href="/prospects?status=contatado">Contatados</a> |
  <a href="/prospects?status=respondeu">Responderam</a> |
  <a href="/prospects?status=interessado">Interessados</a> |
  <a href="/prospects?status=reuniao">Reunião</a> |
  <a href="/prospects?status=cliente_confirmado">Clientes</a> |
  <a href="/prospects?status=ignorado">Ignorados</a> |
  <a href="/prospects?status=nao_contatar">Não contatar</a>

  <br><br>

  <strong>Telefone:</strong>
  <a href="/prospects?phone=with">Com telefone</a> |
  <a href="/prospects?phone=without">Sem telefone</a>
</div>

<br>

<table>
  <thead>
    <tr>
      <th>Clínica</th>
      <th>Contato</th>
      <th>Cidade</th>
      <th>Status</th>
      <th>Último contato</th>
      <th>Bloqueio até</th>
      <th>Ações</th>
    </tr>
  </thead>

  <tbody>
    <% @prospects.each do |prospect| %>
      <% raw_phone = prospect[:whatsapp].to_s.empty? ? prospect[:phone].to_s : prospect[:whatsapp].to_s %>
      <% clean_phone = raw_phone.gsub(/\D/, "") %>
      <% message = "Olá, tudo bem? Sou da Fluxo Clínicas. Ajudamos clínicas odontológicas a reativar pacientes antigos pelo WhatsApp e entregar somente os interessados para agendamento. Posso te mostrar como funcionaria para a sua clínica?" %>
      <% whatsapp_url = clean_phone.empty? ? nil : "https://wa.me/#{clean_phone}?text=#{Rack::Utils.escape(message)}" %>

      <tr>
        <td>
          <strong><%= h prospect[:name].to_s.empty? ? "Sem nome informado" : prospect[:name] %></strong><br>
          <span class="muted"><%= h prospect[:address] %></span><br>
          <span class="muted">Fonte: <%= h prospect[:source] %> <%= h prospect[:source_id] %></span>
        </td>

        <td>
          <% if raw_phone.empty? %>
            <span class="muted">Sem telefone</span>
          <% else %>
            <%= h raw_phone %>
          <% end %>

          <br>

          <% unless prospect[:website].to_s.empty? %>
            <a href="<%= h prospect[:website] %>" target="_blank">Site</a>
          <% end %>
        </td>

        <td><%= h prospect[:city] %></td>
        <td><%= h prospect[:status] %></td>
        <td><%= prospect[:last_contacted_at] %></td>
        <td><%= prospect[:do_not_contact_until] %></td>

        <td>
          <% if whatsapp_url %>
            <a class="button" href="<%= whatsapp_url %>" target="_blank">Abrir WhatsApp</a>
            <br><br>
          <% else %>
            <span class="muted">Sem WhatsApp</span>
            <br><br>
          <% end %>

          <form method="post" action="/prospects/<%= prospect[:id] %>/contacted">
            <button type="submit">Marcar contatado</button>
          </form>

          <br>

          <a class="button" href="/prospects/<%= prospect[:id] %>/response">Registrar resposta</a>

          <br><br>

          <form method="post" action="/prospects/<%= prospect[:id] %>/promote">
            <button type="submit">Virou cliente</button>
          </form>

          <br>

          <a href="/prospects/<%= prospect[:id] %>/events">Histórico</a>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
